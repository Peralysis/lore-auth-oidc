# Required
ADAPTER_PUBLIC_URL=https://auth.example.com
OIDC_ISSUER_URL=https://identity.example.com/application/o/lore/
OIDC_CLIENT_ID=lore-auth-oidc
OIDC_CLIENT_SECRET_FILE=/run/secrets/oidc-client-secret
# Comma/space-separated if the Lore server is reachable under more than one
# hostname (e.g. JWT_AUDIENCE=localhost,127.0.0.1 for the same local server).
JWT_AUDIENCE=lore.example.com
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt-private.pem

# Optional overrides (defaults shown or derived from ADAPTER_PUBLIC_URL)
# GRPC_BIND_ADDR=0.0.0.0:50051
# HTTP_BIND_ADDR=0.0.0.0:8080
# OIDC_REDIRECT_URL=https://auth.example.com/callback
# OIDC_SCOPES=openid profile email
# OIDC_CLIENT_AUTH_METHOD=client_secret_basic
# OIDC_DISPLAY_NAME_CLAIM=name
# OIDC_USERNAME_CLAIM=preferred_username
# OIDC_PROVIDER_NAME=authentik
# Extra PEM root CA bundle to trust, for identity providers behind a
# reverse proxy or TLS-terminating gateway that uses a private CA:
# OIDC_TLS_ROOT_CA_FILE=/run/secrets/internal-root-ca.pem
# JWT_ISSUER=https://auth.example.com
# JWT_KEY_ID=lore-key-1
# SESSION_TTL_SECONDS=600
# ALLOW_ALL_USERS=false
# LORE_ENV=production
RUST_LOG=info
